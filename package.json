{
  "name": "performance-qa-platform",
  "version": "1.0.0",
  "description": "Healthcare patient intake form with full performance + validation test strategy",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:security": "jest tests/security --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:e2e": "playwright test",
    "test:perf": "k6 run tests/performance/load-test.js"
  },
  "dependencies": {
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "express-validator": "7.0.1",
    "helmet": "7.1.0",
    "morgan": "1.10.0",
    "uuid": "9.0.0",
    "xss": "1.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.40.1",
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "supertest": "6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathPattern": "tests/(unit|integration|security)",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
