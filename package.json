{
  "name": "performance-qa-platform",
  "version": "1.0.0",
  "description": "Healthcare patient intake form with full performance + validation test strategy",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:security": "jest tests/security --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:e2e": "playwright test",
    "test:perf": "k6 run tests/performance/load-test.js"
  },
  "dependencies": {
    "express": "4.22.2",
    "express-rate-limit": "7.5.0",
    "express-validator": "^7.3.2",
    "helmet": "8.0.0",
    "morgan": "1.10.1",
    "uuid": "^11.1.1",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@babel/generator": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@playwright/test": "^1.60.0",
    "jest": "29.7.0",
    "nodemon": "3.1.10",
    "supertest": "7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/unit/**/*.test.js",
      "**/tests/integration/**/*.test.js",
      "**/tests/security/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
